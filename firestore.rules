rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Product Validation Blueprint
    function isValidProduct(data) {
      return data.keys().hasAll(['sku', 'name', 'price', 'cost', 'stock', 'minStockAlert', 'category', 'createdAt', 'updatedAt', 'ownerId'])
        && data.keys().hasOnly(['id', 'sku', 'name', 'description', 'price', 'cost', 'stock', 'minStockAlert', 'category', 'imageBase64', 'isReordering', 'createdAt', 'updatedAt', 'ownerId'])
        && data.sku is string && data.sku.size() <= 50
        && data.name is string && data.name.size() <= 100
        && data.price is number && data.price >= 0
        && data.cost is number && data.cost >= 0
        && data.stock is number && data.stock >= 0
        && data.minStockAlert is number && data.minStockAlert >= 0
        && data.category is string && data.category.size() <= 50
        && data.ownerId == request.auth.uid
        && (data.createdAt is number || data.createdAt is timestamp)
        && (data.updatedAt is number || data.updatedAt is timestamp)
        && (!('id' in data) || (data.id is string && data.id.size() <= 128))
        && (!('description' in data) || (data.description is string && data.description.size() <= 1000))
        && (!('imageBase64' in data) || (data.imageBase64 is string && data.imageBase64.size() <= 1048576))
        && (!('isReordering' in data) || (data.isReordering is bool));
    }

    // Sale Validation Blueprint
    function isValidSaleItem(item) {
      return item.keys().hasAll(['id', 'sku', 'name', 'price', 'quantity'])
        && item.keys().hasOnly(['id', 'sku', 'name', 'price', 'quantity', 'imageBase64', 'stock', 'cost', 'minStockAlert', 'category', 'createdAt', 'updatedAt', 'ownerId', 'description', 'serialNumbers', 'isReordering'])
        && item.id is string && item.id.size() <= 128
        && item.sku is string && item.sku.size() <= 50
        && item.name is string && item.name.size() <= 100
        && item.price is number
        && item.quantity is number && item.quantity > 0
        && (!('serialNumbers' in item) || (item.serialNumbers is list && item.serialNumbers.size() == item.quantity))
        && (!('isReordering' in item) || (item.isReordering is bool));
    }

    function isValidSale(data) {
      return data.keys().hasAll(['date', 'items', 'subtotal', 'tax', 'total', 'invoiceNumber', 'ownerId'])
        && data.keys().hasOnly(['date', 'items', 'subtotal', 'tax', 'total', 'discount', 'shipping', 'customerName', 'customerEmail', 'customerPhone', 'customerAddress', 'transport', 'invoiceNumber', 'ownerId', 'id', 'status', 'documentType', 'clientDocumentType', 'currency', 'exchangeRate', 'paymentMethod', 'clientDocumentNumber', 'paymentReference', 'notes', 'customerId'])
        && data.ownerId == request.auth.uid
        && (data.date is number || data.date is timestamp)
        && data.items is list && data.items.size() <= 100
        && (data.items.size() == 0 || isValidSaleItem(data.items[0]))
        && data.subtotal is number
        && data.tax is number
        && data.total is number
        && data.invoiceNumber is string && data.invoiceNumber.size() <= 50
        && (!('documentType' in data) || (data.documentType in ['RECIBO_OFICIAL', 'PROFORMA']))
        && (!('clientDocumentType' in data) || (data.clientDocumentType in ['CEDULA', 'RUC', 'PASAPORTE', 'NINGUNO']))
        && (!('currency' in data) || (data.currency in ['NIO', 'USD']))
        && (!('exchangeRate' in data) || (data.exchangeRate is number && data.exchangeRate >= 0.01))
        && (!('paymentMethod' in data) || (data.paymentMethod in ['EFECTIVO', 'TRANSFERENCIA', 'TARJETA', 'CREDITO']))
        && (!('clientDocumentNumber' in data) || (data.clientDocumentNumber is string))
        && (!('paymentReference' in data) || (data.paymentReference is string))
        && (!('notes' in data) || (data.notes is string))
        && (!('customerId' in data) || (data.customerId is string && data.customerId.size() <= 128))
        && (!('status' in data) || (data.status in ['completed', 'returned', 'cancelled']))
        && (!('customerName' in data) || (data.customerName is string && data.customerName.size() <= 100))
        && (!('customerEmail' in data) || (data.customerEmail is string && data.customerEmail.size() <= 100))
        && (!('customerPhone' in data) || (data.customerPhone is string && data.customerPhone.size() <= 50))
        && (!('customerAddress' in data) || (data.customerAddress is string && data.customerAddress.size() <= 500))
        && (!('transport' in data) || (data.transport is string && data.transport.size() <= 100))
        && (!('discount' in data) || (data.discount is number))
        && (!('shipping' in data) || (data.shipping is number))
        && (!('id' in data) || (data.id is string && data.id.size() <= 128));
    }

    function isValidPurchaseTrackingItem(item) {
      return item.keys().hasAll(['itemId', 'quantity'])
        && item.itemId is string
        && item.quantity is number;
    }

    function isValidPurchaseTracking(tracking) {
      return tracking.keys().hasAll(['id', 'trackingNumber', 'status', 'isReceived', 'itemsInBox'])
        && tracking.keys().hasOnly(['id', 'trackingNumber', 'status', 'agentDeliveryDate', 'receptionDate', 'finalWeight', 'isReceived', 'itemsInBox'])
        && tracking.id is string
        && tracking.trackingNumber is string
        && tracking.status is string
        && tracking.isReceived is bool
        && tracking.itemsInBox is list && (tracking.itemsInBox.size() == 0 || isValidPurchaseTrackingItem(tracking.itemsInBox[0]))
        && (!('agentDeliveryDate' in tracking) || tracking.agentDeliveryDate is number)
        && (!('receptionDate' in tracking) || tracking.receptionDate is number)
        && (!('finalWeight' in tracking) || tracking.finalWeight is number);
    }

    function isValidPurchaseItem(item) {
      return item.keys().hasAll(['id', 'sku', 'name', 'cost', 'quantity', 'receivedQuantity'])
        && item.keys().hasOnly(['id', 'sku', 'name', 'cost', 'quantity', 'receivedQuantity', 'serialNumbers', 'color', 'estimatedWeight'])
        && item.id is string && item.cost is number && item.quantity is number && item.receivedQuantity is number
        && (!('serialNumbers' in item) || (item.serialNumbers is list && item.serialNumbers.size() == item.quantity))
        && (!('color' in item) || (item.color is string))
        && (!('estimatedWeight' in item) || (item.estimatedWeight is number));
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['date', 'items', 'totalCost', 'ownerId', 'currency', 'exchangeRate', 'trackings'])
        && data.keys().hasOnly([
           'date', 'items', 'totalCost', 'supplier', 'notes', 'invoiceNumber', 'ownerId', 'id', 'currency', 'exchangeRate',
           'platform', 'shippingChannel', 'shippingModality', 'orderNumber', 'financing', 'estimatedWeight',
           'trackings', 'status', 'stockAdded', 'freightCost', 'customsTaxes', 'insuranceCost'
        ])
        && data.ownerId == request.auth.uid
        && data.currency in ['NIO', 'USD']
        && data.exchangeRate is number && data.exchangeRate >= 0.01
        && data.items is list && (data.items.size() == 0 || isValidPurchaseItem(data.items[0]))
        && data.trackings is list && (data.trackings.size() == 0 || isValidPurchaseTracking(data.trackings[0]))
        && data.totalCost is number
        && (!('status' in data) || (data.status in ['OPEN', 'PARTIAL', 'CLOSED']))
        && (!('stockAdded' in data) || (data.stockAdded is bool))
        && (!('platform' in data) || (data.platform is string))
        && (!('shippingChannel' in data) || (data.shippingChannel is string))
        && (!('shippingModality' in data) || (data.shippingModality is string))
        && (!('orderNumber' in data) || (data.orderNumber is string))
        && (!('financing' in data) || (data.financing is string))
        && (!('estimatedWeight' in data) || (data.estimatedWeight is number))
        && (!('freightCost' in data) || (data.freightCost is number))
        && (!('customsTaxes' in data) || (data.customsTaxes is number))
        && (!('insuranceCost' in data) || (data.insuranceCost is number));
    }

    function isValidCompany(data) {
      return true; // placeholder since write rule handles validation inline
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['fullName', 'createdAt', 'ownerId'])
        && data.keys().hasOnly(['id', 'fullName', 'phone', 'email', 'address', 'documentType', 'documentNumber', 'createdAt', 'ownerId'])
        && data.fullName is string && data.fullName.size() <= 100
        && data.ownerId == request.auth.uid
        && (data.createdAt is number || data.createdAt is timestamp)
        && (!('id' in data) || (data.id is string && data.id.size() <= 128))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('email' in data) || (data.email is string && data.email.size() <= 100))
        && (!('address' in data) || (data.address is string && data.address.size() <= 200))
        && (!('documentType' in data) || (data.documentType is string && data.documentType.size() <= 50))
        && (!('documentNumber' in data) || (data.documentNumber is string && data.documentNumber.size() <= 50));
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'createdAt', 'ownerId'])
        && data.keys().hasOnly(['id', 'name', 'contactName', 'phone', 'email', 'createdAt', 'ownerId'])
        && data.name is string && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && (data.createdAt is number || data.createdAt is timestamp)
        && (!('id' in data) || (data.id is string && data.id.size() <= 128))
        && (!('contactName' in data) || (data.contactName is string && data.contactName.size() <= 100))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('email' in data) || (data.email is string && data.email.size() <= 100));
    }

    match /products/{productId} {
      allow get: if isSignedIn() && isValidId(productId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidId(productId) 
        && isValidProduct(incoming())
        && existing().ownerId == request.auth.uid
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly([
            'sku', 'name', 'description', 'price', 'cost', 'stock', 'minStockAlert', 'category', 'imageBase64', 'isReordering', 'updatedAt'
        ]);
      allow delete: if isSignedIn() && isValidId(productId) && existing().ownerId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow get: if isSignedIn() && isValidId(saleId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(saleId) && isValidSale(incoming());
      allow update: if isSignedIn() && isValidId(saleId) && existing().ownerId == request.auth.uid && isValidSale(incoming());
      allow delete: if isSignedIn() && isValidId(saleId) && existing().ownerId == request.auth.uid;
    }

    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isValidId(purchaseId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(purchaseId) && isValidPurchase(incoming());
      allow update: if isSignedIn() && isValidId(purchaseId) && existing().ownerId == request.auth.uid && isValidPurchase(incoming());
      allow delete: if isSignedIn() && isValidId(purchaseId) && existing().ownerId == request.auth.uid;
    }

    match /company/{uid} {
      allow get: if isSignedIn() && uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && uid == request.auth.uid 
        && incoming().ownerId == request.auth.uid
        && incoming().keys().hasAll(['name', 'phone', 'address', 'email', 'ownerId'])
        && incoming().keys().hasOnly(['name', 'phone', 'address', 'email', 'logoBase64', 'ownerId', 'defaultExchangeRate'])
        && (!('defaultExchangeRate' in incoming()) || (incoming().defaultExchangeRate is number && incoming().defaultExchangeRate >= 0.01));
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && isValidId(customerId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isSignedIn() && isValidId(customerId) && existing().ownerId == request.auth.uid && isValidCustomer(incoming());
      allow delete: if isSignedIn() && isValidId(customerId) && existing().ownerId == request.auth.uid;
    }

    match /suppliers/{supplierId} {
      allow get: if isSignedIn() && isValidId(supplierId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(supplierId) && isValidSupplier(incoming());
      allow update: if isSignedIn() && isValidId(supplierId) && existing().ownerId == request.auth.uid && isValidSupplier(incoming());
      allow delete: if isSignedIn() && isValidId(supplierId) && existing().ownerId == request.auth.uid;
    }
  }
}
